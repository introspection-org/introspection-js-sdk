            "text": "{\"contents\":[{\"parts\":[{\"text\":\"What is 2+2? Think step by step.\"}],\"role\":\"user\"}],\"generationConfig\":{\"thinkingConfig\":{\"thinkingBudget\":2048,\"includeThoughts\":true}}}"
