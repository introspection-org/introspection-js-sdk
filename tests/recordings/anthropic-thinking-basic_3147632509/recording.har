            "text": "{\"model\":\"claude-sonnet-4-6\",\"max_tokens\":8000,\"thinking\":{\"type\":\"enabled\",\"budget_tokens\":5000},\"messages\":[{\"role\":\"user\",\"content\":\"What is 2+2? Think step by step.\"}]}"
