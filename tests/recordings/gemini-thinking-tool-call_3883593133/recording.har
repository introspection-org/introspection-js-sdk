            "text": "{\"contents\":[{\"parts\":[{\"text\":\"What is the current temperature in Paris and London? Use the tool for both.\"}],\"role\":\"user\"}],\"tools\":[{\"functionDeclarations\":[{\"name\":\"get_current_temperature\",\"description\":\"Get the current temperature in a given city.\",\"parameters\":{\"type\":\"OBJECT\",\"properties\":{\"city\":{\"type\":\"STRING\",\"description\":\"City name\"}},\"required\":[\"city\"]}}]}],\"generationConfig\":{\"thinkingConfig\":{\"thinkingBudget\":1024,\"includeThoughts\":true}}}"
