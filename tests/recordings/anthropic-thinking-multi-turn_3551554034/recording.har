            "text": "{\"model\":\"claude-sonnet-4-6\",\"max_tokens\":8000,\"thinking\":{\"type\":\"enabled\",\"budget_tokens\":5000},\"messages\":[{\"role\":\"user\",\"content\":\"What is the weather in Tokyo?\"},{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"The user wants to know the weather in Tokyo. I'll call the get_weather function.\",\"signature\":\"\"},{\"type\":\"text\",\"text\":\"Sure! Let me check the weather in Tokyo for you right now!\"},{\"type\":\"tool_use\",\"id\":\"toolu_01AarUxYhwUmQ99rnJ341AUD\",\"name\":\"get_weather\",\"input\":{\"city\":\"Tokyo\"},\"caller\":{\"type\":\"direct\"}}]},{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"tool_use_id\":\"toolu_01AarUxYhwUmQ99rnJ341AUD\",\"content\":\"Clear, 25°C\"}]},{\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"The current weather in **Tokyo** is:\\n- 🌤️ **Conditions:** Clear\\n- 🌡️ **Temperature:** 25°C (77°F)\\n\\nIt looks like a nice, clear day in Tokyo! Perfect weather to be outside. 😊\"}]},{\"role\":\"user\",\"content\":\"What is that temperature in Fahrenheit?\"}]}"
          },
