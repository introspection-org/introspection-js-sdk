            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-sonnet-4-5-20250929\",\"max_tokens\":8000,\"thinking\":{\"type\":\"enabled\",\"budget_tokens\":5000},\"messages\":[{\"role\":\"user\",\"content\":\"What is the weather in Tokyo?\"},{\"role\":\"assistant\",\"content\":[{\"type\":\"thinking\",\"thinking\":\"The user is asking about the weather in Tokyo. I have access to a get_weather function that takes a city name as a parameter. I have all the information I need to make this call - the city is \\\"Tokyo\\\".\",\"signature\":\"\"},{\"type\":\"tool_use\",\"id\":\"toolu_01PPtLoiy2xxV1bz1UzddTks\",\"name\":\"get_weather\",\"input\":{\"city\":\"Tokyo\"},\"caller\":{\"type\":\"direct\"}}]},{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"tool_use_id\":\"toolu_01PPtLoiy2xxV1bz1UzddTks\",\"content\":\"Clear, 25°C\"}]},{\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"The weather in Tokyo is currently clear with a temperature of 25°C (77°F).\"}]},{\"role\":\"user\",\"content\":\"What is that temperature in Fahrenheit?\"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
