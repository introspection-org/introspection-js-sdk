            "text": "{\"model\":\"gpt-4o\",\"instructions\":\"Use the DeepWiki MCP tools to answer questions about code repositories. Be very concise.\",\"input\":[{\"role\":\"user\",\"content\":\"What programming language is the openai/openai-agents-python repo written in? One word answer.\"}],\"include\":[],\"tools\":[{\"type\":\"mcp\",\"server_label\":\"deepwiki\",\"server_url\":\"https://mcp.deepwiki.com/mcp\",\"require_approval\":\"never\"}],\"stream\":false}"
