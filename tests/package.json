{
  "name": "introspection-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:processors": "vitest run processors/",
    "test:observability": "vitest run observability/",
    "test:record": "POLLY_MODE=record vitest run",
    "test:replay": "POLLY_MODE=replay vitest run",
    "test:cov": "vitest run --coverage",
    "test:cov:check": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary"
  },
