    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@pollyjs/adapter-fetch": "^6.0.6",
    "@pollyjs/adapter-node-http": "^6.0.6",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.7",
    "ai": "^6.0.191",
    "dotenv": "^16.4.0",
    "openai": "^6.39.0",
