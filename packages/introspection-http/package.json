{
  "name": "@introspection-sdk/http",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Isomorphic HTTP transport, AG-UI stream parsing, error mapping, and cursor pagination shared by the Introspection browser and Node SDKs",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "build": "tsc",
    "prepare": "tsc"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.20.1",
    "eslint": "^9.39.5",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@ag-ui/core": "0.0.57",
    "@introspection-sdk/types": "workspace:*"
  }
}
