{
  "name": "@introspection-sdk/introspection-pi",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Introspection observability extension for the Pi Agent SDK — OTEL GenAI semantic-convention spans for chat completions and tool execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "prepare": "tsc"
  },
  "dependencies": {
    "@introspection-sdk/types": "workspace:*",
    "@opentelemetry/api": "^1.9.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.75.0",
    "@earendil-works/pi-agent-core": ">=0.75.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-agent-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.20.1",
    "eslint": "^9.39.5",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
