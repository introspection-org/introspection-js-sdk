      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./otel": {
      "types": "./dist/otel/index.d.ts",
      "default": "./dist/otel/index.js"
    },
    "./otel/register": {
      "types": "./dist/otel/register.d.ts",
      "default": "./dist/otel/register.js"
    },
    "./mastra": {
      "types": "./dist/otel/mastra-exporter.d.ts",
      "default": "./dist/otel/mastra-exporter.js"
    },
    "./langchain": {
      "types": "./dist/otel/langchain-handler.d.ts",
      "default": "./dist/otel/langchain-handler.js"
    }
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "build": "tsc",
    "prepare": "tsc"
  },
