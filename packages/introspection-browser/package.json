    "typescript": "5.9.2"
  },
  "dependencies": {
    "@introspection-sdk/types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.209.0",
    "@opentelemetry/sdk-logs": "^0.209.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.209.0"
  }
