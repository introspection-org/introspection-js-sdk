{
  "name": "@introspection-sdk/introspection-openclaw",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Introspection observability plugin for OpenClaw — OTEL GenAI semantic convention spans",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "prepare": "tsc"
  },
  "dependencies": {
    "@introspection-sdk/types": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.20.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
