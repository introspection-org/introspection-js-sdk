{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "INTROSPECTION_BASE_API_URL",
    "INTROSPECTION_BASE_OTEL_URL",
    "INTROSPECTION_PROJECT_ID",
    "INTROSPECTION_TOKEN",
    "INTROSPECTION_LOG_LEVEL",
    "INTROSPECTION_SERVICE_NAME",
    "INTROSPECTION_STRICT_TRACING",
    "HTTPS_PROXY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
