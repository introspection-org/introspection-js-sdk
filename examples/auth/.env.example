# Copy to .env.local and fill in the values for the modes you want to try.
# See README.md for how to create the applications via the public API.

# ── Shared ──
# The Introspection project all modes scope tokens to (one project = one
# customer tenant). Public so the client-side flows can read it.
NEXT_PUBLIC_INTROSPECTION_PROJECT=my-project
# Control Plane base URL — the only URL you configure. The broker (server) and
# the spa hosted-login pages (browser) both use it. The Data Plane URL is NOT
# set here: the CP returns it on the token response and the broker forwards it
# to the browser.
# Hosted: https://api.introspection.dev
NEXT_PUBLIC_INTROSPECTION_CP_URL=http://localhost:8000
# Runtime resolved by the broker server-side. Set INTRO_RUNTIME to override
# the default "customer-agent"; the broker turns it into the current runtime_id
# on each session. Runtime resolution is a Control Plane call, so the broker
# always uses the service-account credentials below — for EVERY mode (federated
# and spa included), not just service_account.
INTRO_RUNTIME=customer-agent

# ── SPA mode (public, hosted login — authorization_code + PKCE) ──
# A `spa` application's client_id. Register redirect_uri http://localhost:3200/callback.
NEXT_PUBLIC_INTROSPECTION_SPA_CLIENT_ID=intro_app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Service-account mode (confidential machine — server-side secret) ──
# A `service_account` application + a minted client secret. Project access, no
# end-user identity. Server-only (no NEXT_PUBLIC_ prefix) — never sent to the browser.
INTROSPECTION_SERVICE_ACCOUNT_CLIENT_ID=intro_app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTROSPECTION_SERVICE_ACCOUNT_CLIENT_SECRET=intro_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── JWKS / federated mode (bring-your-own-IdP — RFC 8693 token-exchange) ──
# Application type the federation lives on (matches the CP `application_type`),
# which determines how the subject_token is verified:
#   jwks (default) — the partner IdP's own JWT (e.g. a Supabase session access
#                    token) is verified at CP against {issuer}/.well-known/jwks.json.
#                    The sample signs in at Supabase headlessly — no redirect.
#   spa            — brokered through a per-app customers org (redirect flow).
NEXT_PUBLIC_APPLICATION_TYPE=jwks
# The federation application's client_id (the broker reads it server-side).
FEDERATED_CLIENT_ID=intro_app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-only project selector the broker scopes the token-exchange to. Falls
# back to NEXT_PUBLIC_INTROSPECTION_PROJECT when unset.
INTRO_PROJECT=
# The customer's OWN IdP that Introspection verifies/brokers. Swapping Okta ↔
# Supabase ↔ Auth0 is config only — no code change. Public so the UI can show
# where the user signs in. The IdP client_secret lives only in the application's
# idps registration on the platform, NEVER here.
NEXT_PUBLIC_IDP_PROVIDER=supabase        # okta | supabase | auth0 | neon | generic
NEXT_PUBLIC_IDP_ISSUER=https://<ref>.supabase.co/auth/v1
NEXT_PUBLIC_IDP_CLIENT_ID=
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Brokered customers-org helpers (only used by the brokered `spa` flow).
NEXT_PUBLIC_ZITADEL_ISSUER_URL=
NEXT_PUBLIC_BROKERED_EXTERNAL_ORG_ID=
NEXT_PUBLIC_BROKERED_AUDIENCE_CLIENT_ID=

# ── Partner MCP (identity assertion) ──
# Where the platform publishes this application's assertion JWKS; the sample MCP
# server verifies every request's bearer against it. Use the jwks app's client_id:
MCP_ASSERTION_JWKS_URL=http://localhost:8000/v1/applications/<client_id>/.well-known/jwks.json
# The audience the assertion is bound to — must equal the endpoint's base_url
# registered on the platform (the sandbox-reachable URL of this app's /api/mcp).
MCP_SERVER_URL=http://host.docker.internal:3200/api/mcp
# Where get_value/set_value store data: `memory` (default — in-process Map),
# `supabase`, or `neon` (RLS demos — values live in an RLS-protected table and
# the MCP forwards the identity assertion verbatim to PostgREST, so the database
# enforces per-user isolation). See README "Database-enforced isolation (RLS)".
MCP_VALUES_BACKEND=memory
# Neon Data API (PostgREST-compatible) base URL for the `neon` backend.
NEON_DATA_API_URL=
