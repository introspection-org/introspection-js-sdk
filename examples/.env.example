# Introspection SDK
INTROSPECTION_TOKEN=your_introspection_token
INTROSPECTION_BASE_URL=https://otel.introspection.dev

# OpenAI (for OpenAI-based examples)
OPENAI_API_KEY=your_openai_api_key

# Arize/Phoenix (optional)
ARIZE_SPACE_KEY=your_arize_space_key
ARIZE_API_KEY=your_arize_api_key

# Braintrust (optional)
BRAINTRUST_API_KEY=your_braintrust_api_key

# LangSmith (optional — for langchain and claude-agent-langsmith examples)
LANGSMITH_API_KEY=your_langsmith_api_key

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# Anthropic (for Claude Agent SDK examples)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Mastra Cloud (optional)
MASTRA_CLOUD_ACCESS_TOKEN=your_mastra_cloud_access_token
